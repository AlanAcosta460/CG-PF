{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build and run active file",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "g++ -std=c++11 \"${file}\" -o \"${fileBasenameNoExtension}\" -I/usr/local/include -I/opt/homebrew/include -L/usr/local/lib -L/opt/homebrew/lib -lGLEW -lglfw -lassimp -lSOIL2 -framework OpenGL -framework CoreFoundation && ./${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}